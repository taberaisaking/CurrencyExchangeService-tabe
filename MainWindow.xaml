<Window x:Class="CurrencyExchangeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Currency Exchange Office" 
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <!-- From Currency -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="From Currency:" 
                       VerticalAlignment="Center"
                       FontSize="14" Foreground="#2C3E50"/>
            <ComboBox x:Name="FromCurrencyCombo" 
                      Grid.Column="1" Height="35"
                      FontSize="14"/>
        </Grid>

        <!-- Amount -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Amount:" 
                       VerticalAlignment="Center"
                       FontSize="14" Foreground="#2C3E50"/>
            <TextBox x:Name="AmountTextBox" 
                     Grid.Column="1" Height="35"
                     FontSize="14" Padding="5"
                     Text="100"/>
        </Grid>

        <!-- To Currency -->
        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="To Currency:" 
                       VerticalAlignment="Center"
                       FontSize="14" Foreground="#2C3E50"/>
            <ComboBox x:Name="ToCurrencyCombo" 
                      Grid.Column="1" Height="35"
                      FontSize="14"/>
        </Grid>

        <!-- Exchange Button -->
        <Button Grid.Row="4" 
                Content="Exchange Currency" 
                Height="45" FontSize="16"
                Background="#2980B9" 
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="ExchangeButton_Click"
                Margin="0,0,0,20"/>

        <!-- Result -->
        <Border Grid.Row="5" 
                Background="White" 
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,10">
            <TextBlock x:Name="ResultTextBlock" 
                       Text="Result will appear here..." 
                       FontSize="18" 
                       HorizontalAlignment="Center"
                       Foreground="#27AE60"
                       FontWeight="Bold"/>
        </Border>

        <!-- Rates List -->
        <Border Grid.Row="6" 
                Background="White" 
                CornerRadius="8"
                Padding="15">
            <StackPanel>
                <TextBlock Text="Live Exchange Rates (PLN)" 
                           FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>
                <ListBox x:Name="RatesListBox" 
                         BorderThickness="0"
                         FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>