<Window x:Class="CurrencyExchangeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office"
        Height="700" Width="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Title -->
            <TextBlock Text="Currency Exchange Office"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

            <!-- Login/Register Panel -->
            <Border Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="User Account"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Username:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <TextBox x:Name="UsernameTextBox"
                             Grid.Column="1" Height="30"
                             FontSize="13" Padding="5"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Password:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="1" Height="30"
                                 FontSize="13" Padding="5"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <Button Content="Login"
                            Width="100" Height="35"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,10,0"
                            Click="LoginButton_Click"/>
                        <Button Content="Register"
                            Width="100" Height="35"
                            Background="#2980B9"
                            Foreground="White"
                            BorderThickness="0"
                            Click="RegisterButton_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="AccountStatusText"
                           Text="" FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="#E74C3C"
                           Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Balance Panel -->
            <Border Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="BalanceText"
                           Text="Balance: Please login"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="#2C3E50"/>
                    <TextBox x:Name="TopUpTextBox"
                         Grid.Column="1"
                         Height="30" FontSize="13"
                         Padding="5" Text="500"
                         Margin="0,0,5,0"/>
                    <TextBlock Text="PLN"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                    <Button Content="Top Up"
                        Grid.Column="3"
                        Height="30"
                        Background="#8E44AD"
                        Foreground="White"
                        BorderThickness="0"
                        Click="TopUpButton_Click"/>
                </Grid>
            </Border>

            <!-- Exchange Panel -->
            <Border Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Currency Exchange"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="From Currency:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <ComboBox x:Name="FromCurrencyCombo"
                              Grid.Column="1" Height="32"
                              FontSize="13"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Amount:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <TextBox x:Name="AmountTextBox"
                             Grid.Column="1" Height="32"
                             FontSize="13" Padding="5"
                             Text="100"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="To Currency:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <ComboBox x:Name="ToCurrencyCombo"
                              Grid.Column="1" Height="32"
                              FontSize="13"/>
                    </Grid>
                    <Button Content="Exchange Currency"
                        Height="40" FontSize="14"
                        Background="#2980B9"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ExchangeButton_Click"/>
                    <TextBlock x:Name="ResultTextBlock"
                           Text="Result will appear here..."
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="#27AE60"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Buy/Sell Panel -->
            <Border Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Buy / Sell Currency"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Currency:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <ComboBox x:Name="BuySellCurrencyCombo"
                              Grid.Column="1" Height="32"
                              FontSize="13"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Amount:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                        <TextBox x:Name="BuySellAmountTextBox"
                             Grid.Column="1" Height="32"
                             FontSize="13" Padding="5"
                             Text="100"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <Button Content="Buy Currency"
                            Width="130" Height="38"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,10,0"
                            Click="BuyButton_Click"/>
                        <Button Content="Sell Currency"
                            Width="130" Height="38"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Click="SellButton_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="BuySellResultText"
                           Text="" FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="#27AE60"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Transaction History -->
            <Border Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Transaction History"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                        <Button Content="Refresh"
                            Grid.Column="1"
                            Height="28" Width="70"
                            Background="#7F8C8D"
                            Foreground="White"
                            BorderThickness="0"
                            Click="RefreshHistoryButton_Click"/>
                    </Grid>
                    <ListBox x:Name="HistoryListBox"
                         BorderThickness="0"
                         FontSize="12"
                         Height="80"/>
                </StackPanel>
            </Border>

            <!-- Live Rates -->
            <Border Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Live Exchange Rates (PLN)"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"/>
                    <ListBox x:Name="RatesListBox"
                         BorderThickness="0"
                         FontSize="12"
                         Height="120"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>