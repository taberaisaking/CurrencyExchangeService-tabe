<Window x:Class="CurrencyExchangeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" 
        Height="600" Width="650"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Currency Exchange Office"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <!-- Login/Register Panel -->
        <Border Grid.Row="1" Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="User Account"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Username:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                    <TextBox x:Name="UsernameTextBox"
                             Grid.Column="1" Height="30"
                             FontSize="13" Padding="5"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Password:"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="1" Height="30"
                                 FontSize="13" Padding="5"/>
                </Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="Login"
                            Width="100" Height="35"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,10,0"
                            Click="LoginButton_Click"/>
                    <Button Content="Register"
                            Width="100" Height="35"
                            Background="#2980B9"
                            Foreground="White"
                            BorderThickness="0"
                            Click="RegisterButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="AccountStatusText"
                           Text="" FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="#E74C3C"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Balance Panel -->
        <Border Grid.Row="2" Background="White"
                CornerRadius="8" Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BalanceText"
                           Text="Balance: Please login"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="#2C3E50"/>
                <TextBox x:Name="TopUpTextBox"
                         Grid.Column="1"
                         Width="80" Height="30"
                         FontSize="13" Padding="5"
                         Text="500" Margin="0,0,5,0"/>
                <TextBlock Text="PLN"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                <Button Content="Top Up"
                        Grid.Column="3"
                        Height="30" Width="70"
                        Background="#8E44AD"
                        Foreground="White"
                        BorderThickness="0"
                        Click="TopUpButton_Click"/>
            </Grid>
        </Border>

        <!-- From Currency -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="From Currency:"
                       VerticalAlignment="Center"
                       FontSize="14" Foreground="#2C3E50"/>
            <ComboBox x:Name="FromCurrencyCombo"
                      Grid.Column="1" Height="35"
                      FontSize="14"/>
        </Grid>

        <!-- Amount -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Amount:"
                       VerticalAlignment="Center"
                       FontSize="14" Foreground="#2C3E50"/>
            <TextBox x:Name="AmountTextBox"
                     Grid.Column="1" Height="35"
                     FontSize="14" Padding="5"
                     Text="100"/>
        </Grid>

        <!-- To Currency -->
        <Grid Grid.Row="5" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="To Currency:"
                       VerticalAlignment="Center"
                       FontSize="14" Foreground="#2C3E50"/>
            <ComboBox x:Name="ToCurrencyCombo"
                      Grid.Column="1" Height="35"
                      FontSize="14"/>
        </Grid>

        <!-- Exchange Button -->
        <Button Grid.Row="6"
                Content="Exchange Currency"
                Height="45" FontSize="16"
                Background="#2980B9"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="ExchangeButton_Click"
                Margin="0,0,0,15"/>

        <!-- Result and Rates -->
        <Grid Grid.Row="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="White"
                    CornerRadius="8" Padding="15"
                    Margin="0,0,0,10">
                <TextBlock x:Name="ResultTextBlock"
                           Text="Result will appear here..."
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Foreground="#27AE60"
                           FontWeight="Bold"/>
            </Border>
            <Border Grid.Row="1" Background="White"
                    CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Live Exchange Rates (PLN)"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,10"/>
                    <ListBox x:Name="RatesListBox"
                             BorderThickness="0"
                             FontSize="13"
                             Height="100"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>